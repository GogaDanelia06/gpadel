# Application
NEXT_PUBLIC_BASE_URL=https://gpadel.ge

# BOG Pay (Bank of Georgia) credentials
# Get these from BOG Developer Portal: https://developer.bog.ge
BOG_CLIENT_ID=your_bog_client_id_here
BOG_CLIENT_SECRET=your_bog_client_secret_here

# TBC iPay credentials
# Get these from TBC Developer Portal: https://developer.tbcbank.ge
TBC_API_KEY=your_tbc_api_key_here
TBC_SECRET=your_tbc_secret_here

# Optional: override data directory for reservations
# DATA_DIR=./data
